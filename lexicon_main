// ============ SOUND ENGINE (Web Audio API) ============
class SoundEngine {
  constructor() {
    this.ctx = null;
    this.muted = false;
    this.musicNodes = [];
  }
  init() {
    if (!this.ctx) {
      try {
        this.ctx = new (window.AudioContext || window.webkitAudioContext)();
      } catch (e) { /* no audio support */ }
    }
    if (this.ctx && this.ctx.state === 'suspended') this.ctx.resume();
  }
  toggle() { this.muted = !this.muted; if (this.muted) this.stopMusic(); return this.muted; }
  
  // Basic tone generator
  tone(freq, duration, type = 'square', volume = 0.15, delay = 0) {
    if (!this.ctx || this.muted) return;
    const now = this.ctx.currentTime + delay;
    const osc = this.ctx.createOscillator();
    const gain = this.ctx.createGain();
    osc.type = type;
    osc.frequency.setValueAtTime(freq, now);
    gain.gain.setValueAtTime(0, now);
    gain.gain.linearRampToValueAtTime(volume, now + 0.01);
    gain.gain.exponentialRampToValueAtTime(0.001, now + duration);
    osc.connect(gain);
    gain.connect(this.ctx.destination);
    osc.start(now);
    osc.stop(now + duration);
  }
  
  // Sweep (for attacks)
  sweep(startFreq, endFreq, duration, type = 'sawtooth', volume = 0.15) {
    if (!this.ctx || this.muted) return;
    const now = this.ctx.currentTime;
    const osc = this.ctx.createOscillator();
    const gain = this.ctx.createGain();
    osc.type = type;
    osc.frequency.setValueAtTime(startFreq, now);
    osc.frequency.exponentialRampToValueAtTime(endFreq, now + duration);
    gain.gain.setValueAtTime(volume, now);
    gain.gain.exponentialRampToValueAtTime(0.001, now + duration);
    osc.connect(gain);
    gain.connect(this.ctx.destination);
    osc.start(now);
    osc.stop(now + duration);
  }
  
  // Noise burst (for hits, damage)
  noise(duration, volume = 0.1, filterFreq = 1000) {
    if (!this.ctx || this.muted) return;
    const now = this.ctx.currentTime;
    const bufferSize = this.ctx.sampleRate * duration;
    const buffer = this.ctx.createBuffer(1, bufferSize, this.ctx.sampleRate);
    const data = buffer.getChannelData(0);
    for (let i = 0; i < bufferSize; i++) data[i] = Math.random() * 2 - 1;
    const noise = this.ctx.createBufferSource();
    noise.buffer = buffer;
    const filter = this.ctx.createBiquadFilter();
    filter.type = 'lowpass';
    filter.frequency.setValueAtTime(filterFreq, now);
    const gain = this.ctx.createGain();
    gain.gain.setValueAtTime(volume, now);
    gain.gain.exponentialRampToValueAtTime(0.001, now + duration);
    noise.connect(filter);
    filter.connect(gain);
    gain.connect(this.ctx.destination);
    noise.start(now);
    noise.stop(now + duration);
  }
  
  // SFX
  playClick() { this.tone(600, 0.05, 'square', 0.08); }
  playSelect() { 
    this.tone(523, 0.08, 'square', 0.1);
    this.tone(784, 0.08, 'square', 0.1, 0.08);
  }
  playHit() {
    this.sweep(800, 200, 0.15, 'sawtooth', 0.2);
    this.noise(0.1, 0.15, 2000);
  }
  playCrit() {
    this.tone(880, 0.08, 'square', 0.18);
    this.tone(1174, 0.08, 'square', 0.18, 0.08);
    this.tone(1568, 0.15, 'square', 0.2, 0.16);
    this.noise(0.1, 0.1, 3000);
  }
  playDamage() {
    this.sweep(300, 80, 0.3, 'sawtooth', 0.2);
    this.noise(0.2, 0.2, 400);
  }
  playCorrect() {
    this.tone(659, 0.1, 'square', 0.12);
    this.tone(988, 0.15, 'square', 0.12, 0.1);
  }
  playWrong() {
    this.tone(200, 0.1, 'sawtooth', 0.15);
    this.tone(150, 0.2, 'sawtooth', 0.15, 0.1);
  }
  playVictory() {
    const notes = [523, 659, 784, 1047];
    notes.forEach((n, i) => this.tone(n, 0.2, 'square', 0.15, i * 0.12));
  }
  playDefeat() {
    const notes = [440, 392, 349, 294, 220];
    notes.forEach((n, i) => this.tone(n, 0.3, 'triangle', 0.15, i * 0.2));
  }
  playBossVictory() {
    const notes = [523, 659, 784, 1047, 1319, 1568];
    notes.forEach((n, i) => this.tone(n, 0.15, 'square', 0.18, i * 0.1));
    // Power chord finale
    this.tone(523, 0.6, 'square', 0.15, 0.6);
    this.tone(659, 0.6, 'square', 0.15, 0.6);
    this.tone(784, 0.6, 'square', 0.15, 0.6);
  }
  playLevelUp() {
    const notes = [392, 523, 659, 784, 1047];
    notes.forEach((n, i) => this.tone(n, 0.12, 'square', 0.15, i * 0.08));
  }
  playPotion() {
    this.sweep(400, 1200, 0.3, 'sine', 0.15);
    this.tone(1400, 0.1, 'sine', 0.1, 0.25);
  }
  playTick() { this.tone(1200, 0.03, 'square', 0.06); }
  playBossAppear() {
    this.sweep(100, 50, 0.8, 'sawtooth', 0.25);
    this.noise(0.6, 0.15, 200);
  }
  
  // Background dungeon ambient loop
  startMusic(isBoss = false) {
    if (!this.ctx || this.muted) return;
    this.stopMusic();
    const baseNotes = isBoss 
      ? [110, 146, 110, 165, 110, 146, 98, 130] // Boss - darker, D minor feel
      : [146, 174, 220, 174, 146, 130, 110, 130]; // Regular dungeon
    const noteLength = isBoss ? 0.35 : 0.4;
    
    const playLoop = () => {
      if (this.muted || !this.ctx) return;
      baseNotes.forEach((freq, i) => {
        this.tone(freq, noteLength * 0.9, 'triangle', 0.05, i * noteLength);
        // Add harmony on every other note
        if (i % 2 === 0) this.tone(freq * 1.5, noteLength * 0.9, 'triangle', 0.03, i * noteLength);
      });
    };
    playLoop();
    const interval = setInterval(playLoop, baseNotes.length * noteLength * 1000);
    this.musicNodes.push(interval);
  }
  
  stopMusic() {
    this.musicNodes.forEach(n => clearInterval(n));
    this.musicNodes = [];
  }
}

